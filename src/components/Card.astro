---
interface Props {
  title: string;
  description: string;
  image?: string;
  imageUrl?: string;
  href?: string;
  badge?: string;
}

const { title, description, image, imageUrl, href, badge } = Astro.props;
---

<div class="border border-border rounded-lg overflow-hidden hover:border-purple/30 transition-colors bg-white">
  {imageUrl ? (
    <div class="h-48 overflow-hidden">
      <img src={imageUrl} alt={title} class="w-full h-full object-cover" loading="lazy" />
    </div>
  ) : image ? (
    <div class="h-48 bg-surface flex items-center justify-center">
      <span class="text-4xl">{image}</span>
    </div>
  ) : null}
  <div class="p-5">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-bold text-lg text-dark">{title}</h3>
      {badge && (
        <span class="text-xs bg-purple/10 text-purple px-2 py-0.5 rounded-full font-medium shrink-0">{badge}</span>
      )}
    </div>
    <p class="text-muted text-sm mt-2 leading-relaxed">{description}</p>
    {href && (
      <a href={href} class="inline-flex items-center gap-1 mt-3 text-sm text-purple font-medium hover:underline">
        Learn more
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    )}
  </div>
</div>
