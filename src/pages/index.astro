---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';

const featuredSevas = [
  { title: 'Abhishekam', description: 'Sacred bathing ceremony for the deities with milk, honey, and holy water.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/2/2f/ISKCON_Juhu_Temple_Altars.JPG' },
  { title: 'Archana', description: 'Chanting of 108 or 1008 names of the Lord for blessings.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/d/d4/Radha_Krishna_ISKCON_Tirupati.JPG' },
];

const upcomingEvents = [
  { title: 'Janmashtami 2026', description: 'Grand celebration of Lord Krishna\'s appearance day with kirtan, drama, and midnight abhishekam.', badge: 'Aug 2026' },
  { title: 'Sunday Love Feast', description: 'Weekly gathering with kirtan, discourse on Bhagavad Gita, and sumptuous prasadam.', badge: 'Every Sunday' },
];

const exploreLinks = [
  { title: 'Temple Sevas', href: '/sevas' },
  { title: 'Spiritual Courses', href: '/courses' },
  { title: 'Events & Festivals', href: '/events' },
  { title: 'Contact Us', href: '/contact' },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://upload.wikimedia.org/wikipedia/commons/9/9e/ISKCON_Juhu_Temple_and_Guesthouse.JPG"
        alt="ISKCON Temple"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative max-w-4xl mx-auto text-center py-28 px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
        ISKCON Tuticorin
      </h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto mb-8">
        ISKCON Tuticorin — A spiritual oasis in the pearl city, dedicated to the path of Bhakti Yoga
        as taught by His Divine Grace A.C. Bhaktivedanta Swami Prabhupada.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/sevas" class="bg-purple hover:bg-purple-dark px-6 py-3 rounded-lg font-medium transition-colors">
          Book a Seva
        </a>
        <a href="/courses" class="border border-white/40 hover:bg-white/10 px-6 py-3 rounded-lg font-medium transition-colors">
          Explore Courses
        </a>
      </div>
    </div>
  </section>

  <!-- Darshan Timings -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="border border-border rounded-lg p-6 flex flex-wrap items-center justify-between gap-4">
      <div>
        <h2 class="font-bold text-dark text-lg">Temple Darshan Timings</h2>
        <p class="text-muted text-sm mt-1">Open for all devotees, every day</p>
      </div>
      <div class="flex gap-8 text-sm">
        <div class="text-center">
          <div class="text-purple font-bold">Morning</div>
          <div class="text-muted">4:30 AM - 1:00 PM</div>
        </div>
        <div class="text-center">
          <div class="text-purple font-bold">Evening</div>
          <div class="text-muted">4:00 PM - 8:30 PM</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Sevas -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl md:text-3xl font-bold text-purple mb-6">Featured Sevas</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {featuredSevas.map(seva => (
        <Card title={seva.title} description={seva.description} imageUrl={seva.imageUrl} href="/sevas" />
      ))}
    </div>
  </section>

  <!-- Upcoming Events -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl md:text-3xl font-bold text-purple mb-6">Upcoming Events</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {upcomingEvents.map(event => (
        <Card title={event.title} description={event.description} badge={event.badge} />
      ))}
    </div>
  </section>

  <hr class="max-w-4xl mx-auto border-border" />

  <!-- Explore More -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl md:text-3xl font-bold text-purple mb-6">Explore more</h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {exploreLinks.map(link => (
        <a href={link.href} class="flex items-center justify-between border border-border rounded-lg px-5 py-4 hover:border-purple/40 transition-colors group">
          <span class="font-medium text-dark group-hover:text-purple transition-colors">{link.title}</span>
          <svg class="w-5 h-5 text-muted group-hover:text-purple transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      ))}
    </div>
  </section>
</Layout>
