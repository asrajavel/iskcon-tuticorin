---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const featuredSevas = [
  { title: 'Abhisheka Seva', description: 'Sacred bathing ceremony for the deities with milk, curd, ghee, honey, and sanctified water.', imageUrl: 'https://iskcontirunelveli.com/wp-content/uploads/2019/08/slide_02-1.jpg' },
  { title: 'Pushpa Seva', description: 'Sponsor beautiful flower decorations for Sri Sri Krishna Balaram. Fresh flowers offered daily.', imageUrl: 'https://iskcontirunelveli.com/wp-content/uploads/2019/08/slide_03-1.jpg' },
];

const upcomingEvents = [
  { title: 'Sri Krishna Janmashtami', description: 'Grand celebration of Lord Krishna\'s appearance day with kirtan, drama performances, midnight abhishekam, and sumptuous prasadam feast.', badge: 'Annual' },
  { title: 'Sunday Special Program', description: 'Weekly gathering with ecstatic kirtan, Bhagavad Gita discourse, and a delicious multi-course prasadam feast. Everyone is welcome!', badge: 'Every Sunday' },
];

const exploreLinks = [
  { title: 'Temple Sevas', href: `${base}/sevas` },
  { title: 'Spiritual Courses', href: `${base}/courses` },
  { title: 'Festivals & Events', href: `${base}/events` },
  { title: 'Contact Us', href: `${base}/contact` },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://iskcontirunelveli.com/wp-content/uploads/2019/10/slide_01.jpg"
        alt="ISKCON Temple"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative max-w-4xl mx-auto text-center py-28 px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 leading-tight">
        Sri Sri Krishna Balaram Temple
      </h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto mb-8">
        ISKCON Tirunelveli — Dedicated to the path of Bhakti Yoga
        as taught by His Divine Grace A.C. Bhaktivedanta Swami Prabhupada.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${base}/sevas`} class="bg-purple hover:bg-purple-dark px-6 py-3 rounded-lg font-medium transition-colors">
          Book a Seva
        </a>
        <a href={`${base}/courses`} class="border border-white/40 hover:bg-white/10 px-6 py-3 rounded-lg font-medium transition-colors">
          Explore Programs
        </a>
      </div>
    </div>
  </section>

  <!-- Darshan Timings -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="border border-border rounded-lg p-6">
      <h2 class="font-bold text-dark text-lg mb-4">Temple Darshan Timings</h2>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <div class="text-purple font-bold mb-2">Morning (4:45 AM - 12:30 PM)</div>
          <div class="space-y-1 text-muted">
            <p>Mangala Arati Darshan: 4:45 - 5:10 AM</p>
            <p>Sringara Darshan: 7:30 - 8:00 AM</p>
            <p>General Darshan: 8:30 - 11:30 AM</p>
            <p>Raj Bhog Arati: 12:00 - 12:30 PM</p>
          </div>
        </div>
        <div>
          <div class="text-purple font-bold mb-2">Evening (4:45 PM - 8:15 PM)</div>
          <div class="space-y-1 text-muted">
            <p>General Darshan: 4:45 - 7:45 PM</p>
            <p>Sandhya Arati: 7:00 PM</p>
            <p>Shayana Arati: 8:00 - 8:15 PM</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Sevas -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl md:text-3xl font-bold text-purple mb-6">Featured Sevas</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {featuredSevas.map(seva => (
        <Card title={seva.title} description={seva.description} imageUrl={seva.imageUrl} href={`${base}/sevas`} />
      ))}
    </div>
  </section>

  <!-- Upcoming Events -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl md:text-3xl font-bold text-purple mb-6">Programs & Events</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {upcomingEvents.map(event => (
        <Card title={event.title} description={event.description} badge={event.badge} />
      ))}
    </div>
  </section>

  <!-- About -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="border border-border rounded-lg p-6">
      <h2 class="text-xl font-bold text-purple mb-3">About ISKCON</h2>
      <p class="text-muted text-sm leading-relaxed">
        The International Society for Krishna Consciousness (ISKCON) was established in 1966 in New York
        by A.C. Bhaktivedanta Swami Prabhupada. Today, ISKCON operates over 600 temples and yoga centers
        worldwide with millions of Krishna devotees. ISKCON is a spiritual organization dedicated to
        serving the welfare of all people — promoting divine consciousness, ethical values, peace, and
        harmony regardless of caste, creed, or religion.
      </p>
      <a href={`${base}/about`} class="inline-flex items-center gap-1 mt-3 text-sm text-purple font-medium hover:underline">
        Learn more
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Articles Preview -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl md:text-3xl font-bold text-purple">Articles</h2>
      <a href={`${base}/articles`} class="text-sm text-purple hover:underline">View all &rarr;</a>
    </div>
    <div class="grid sm:grid-cols-3 gap-5">
      {[
        { slug: 'bhakti-yoga', title: 'Bhakti Yoga', summary: 'Connect to the Supreme by means of loving devotional service.' },
        { slug: 'karma', title: 'Karma', summary: 'The law of karma regulates the reactions to our activities.' },
        { slug: 'who-am-i', title: 'Who Am I?', summary: 'Discovering our eternal spiritual identity and relationship with Krishna.' },
      ].map(article => (
        <a href={`${base}/articles/${article.slug}`} class="border border-border rounded-lg p-5 hover:border-purple/30 transition-colors group">
          <h3 class="font-bold text-dark group-hover:text-purple transition-colors">{article.title}</h3>
          <p class="text-muted text-sm mt-2">{article.summary}</p>
        </a>
      ))}
    </div>
  </section>

  <hr class="max-w-4xl mx-auto border-border" />
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h2 class="text-2xl md:text-3xl font-bold text-purple mb-6">Explore more</h2>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {exploreLinks.map(link => (
        <a href={link.href} class="flex items-center justify-between border border-border rounded-lg px-5 py-4 hover:border-purple/40 transition-colors group">
          <span class="font-medium text-dark group-hover:text-purple transition-colors">{link.title}</span>
          <svg class="w-5 h-5 text-muted group-hover:text-purple transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      ))}
    </div>
  </section>
</Layout>
