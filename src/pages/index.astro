---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const featuredSevas = [
  { title: 'Abhisheka Seva', description: 'Sacred bathing ceremony for the deities with milk, curd, ghee, honey, and sanctified water.', imageUrl: 'https://iskcontirunelveli.com/wp-content/uploads/2019/08/slide_02-1.jpg' },
  { title: 'Pushpa Seva', description: 'Sponsor beautiful flower decorations for Sri Sri Krishna Balaram. Fresh flowers offered daily.', imageUrl: 'https://iskcontirunelveli.com/wp-content/uploads/2019/08/slide_03-1.jpg' },
];

const upcomingEvents = [
  { title: 'Sri Krishna Janmashtami', description: 'Grand celebration of Lord Krishna\'s appearance day with kirtan, drama performances, midnight abhishekam, and sumptuous prasadam feast.', badge: 'Annual' },
  { title: 'Sunday Special Program', description: 'Weekly gathering with ecstatic kirtan, Bhagavad Gita discourse, and a delicious multi-course prasadam feast. Everyone is welcome!', badge: 'Every Sunday' },
];

---

<Layout title="Home">
  <!-- Hero -->
  <section>
    <img
      src={`${base}/images/hero.jpg`}
      alt="Sri Sri Krishna Balaram - ISKCON Tirunelveli"
      class="w-full"
    />
  </section>

  <!-- Darshan Timings -->
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="border border-border rounded-lg p-6">
      <h2 class="font-bold text-dark text-lg mb-4">Temple Darshan Timings</h2>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <div class="text-purple font-bold mb-2">Morning (4:45 AM - 12:30 PM)</div>
          <div class="space-y-1 text-muted">
            <p>Mangala Arati Darshan: 4:45 - 5:10 AM</p>
            <p>Sringara Darshan: 7:30 - 8:00 AM</p>
            <p>General Darshan: 8:30 - 11:30 AM</p>
            <p>Raj Bhog Arati: 12:00 - 12:30 PM</p>
          </div>
        </div>
        <div>
          <div class="text-purple font-bold mb-2">Evening (4:45 PM - 8:15 PM)</div>
          <div class="space-y-1 text-muted">
            <p>General Darshan: 4:45 - 7:45 PM</p>
            <p>Sandhya Arati: 7:00 PM</p>
            <p>Shayana Arati: 8:00 - 8:15 PM</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Sevas -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl md:text-3xl font-bold text-purple mb-6">Featured Sevas</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {featuredSevas.map(seva => (
        <Card title={seva.title} description={seva.description} imageUrl={seva.imageUrl} href={`${base}/sevas`} />
      ))}
    </div>
  </section>

  <!-- Upcoming Events -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl md:text-3xl font-bold text-purple mb-6">Programs & Events</h2>
    <div class="grid md:grid-cols-2 gap-6">
      {upcomingEvents.map(event => (
        <Card title={event.title} description={event.description} badge={event.badge} />
      ))}
    </div>
  </section>

  <!-- Articles Preview -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl md:text-3xl font-bold text-purple">Articles</h2>
      <a href={`${base}/articles`} class="text-sm text-purple hover:underline">View all &rarr;</a>
    </div>
    <div class="grid sm:grid-cols-3 gap-5">
      {[
        { slug: 'bhakti-yoga', title: 'Bhakti Yoga', summary: 'Connect to the Supreme by means of loving devotional service.', image: `${base}/images/articles/bhakti-yoga-1.jpeg` },
        { slug: 'karma', title: 'Karma', summary: 'The law of karma regulates the reactions to our activities.', image: `${base}/images/articles/karma-1.jpeg` },
        { slug: 'who-am-i', title: 'Who Am I?', summary: 'Discovering our eternal spiritual identity and relationship with Krishna.', image: `${base}/images/articles/who-am-i-1.jpeg` },
      ].map(article => (
        <a href={`${base}/articles/${article.slug}`} class="border border-border rounded-lg overflow-hidden hover:border-purple/30 transition-colors group">
          <div class="h-36 overflow-hidden">
            <img src={article.image} alt={article.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-4">
            <h3 class="font-bold text-dark group-hover:text-purple transition-colors">{article.title}</h3>
            <p class="text-muted text-sm mt-1">{article.summary}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
