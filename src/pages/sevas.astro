---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sevas = [
  { title: 'Abhisheka Seva', description: 'Sacred bathing ceremony for the deities with milk, curd, ghee, honey, sweetened water, and sanctified water from nine kalashas.', imageUrl: 'https://donations.iskconwhitefield.org/cdn/shop/files/Untitleddesign_13.png?v=1742070333', price: '₹1,116' },
  { title: 'Pushpa Seva', description: 'Sponsor beautiful fresh flower decorations for Sri Sri Krishna Balaram. Flowers are offered daily with love and devotion.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/5/55/Radha_Krishna-chandra_Temple.jpg', price: '₹501' },
  { title: 'Sunday Prasada Seva', description: 'Sponsor the Sunday Love Feast prasadam for all devotees and guests attending the weekly program.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/f/fb/Sunday_Love_feast.jpg', price: '₹2,500' },
  { title: 'Daily Prasada Seva', description: 'Sponsor daily prasadam distribution to devotees, visitors, and the needy. Serve blessed food to all.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/2/2a/Daily_Free_Prasadam_Distribution_at_ISKCON_Juhu.jpg', price: '₹1,500' },
  { title: 'Classical Dana Seva', description: 'Traditional charitable offerings as prescribed in the scriptures — cows, grains, gold, and other sacred donations.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/4/4f/Nitai-Gauranga.jpg', price: '₹1,001' },
  { title: 'Sri Krishna Year Seva', description: 'Annual sponsorship for year-round deity worship, temple maintenance, and spiritual programs.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/d/d4/Radha_Krishna_ISKCON_Tirupati.JPG', price: '₹10,000' },
  { title: 'Life Membership', description: 'Become a lifetime member of ISKCON Tirunelveli. Includes special darshan privileges, prasadam, and invitation to all festivals.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/2/2f/ISKCON_Juhu_Temple_Altars.JPG', price: 'Contact us' },
  { title: 'Temple Construction', description: 'Contribute to the construction and development of Sri Sri Krishna Balaram Temple. Help build a magnificent house for the Lord.', imageUrl: 'https://upload.wikimedia.org/wikipedia/commons/f/f1/ISKCON_Juhu_Temple.JPG', price: '₹10,000+' },
];
---

<Layout title="Sevas" description="Participate in temple sevas and worship services at ISKCON Tirunelveli">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold text-purple mb-2">Temple Sevas</h1>
    <p class="text-muted max-w-xl mb-10">
      Participate in devotional services at Sri Sri Krishna Balaram Temple and receive the blessings of the Lord.
      All sevas include prasadam for your family.
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sevas.map(seva => (
        <div class="border border-border rounded-lg overflow-hidden hover:border-purple/30 transition-colors bg-white">
          <div class="h-40 overflow-hidden">
            <img src={seva.imageUrl} alt={seva.title} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-bold text-dark">{seva.title}</h3>
              <span class="text-sm text-purple font-bold shrink-0">{seva.price}</span>
            </div>
            <p class="text-muted text-sm mt-2 leading-relaxed">{seva.description}</p>
            <a href="https://pages.razorpay.com/DONATION-TO-ISKCON-TIRUNELVELI" target="_blank" rel="noopener noreferrer" class="mt-4 w-full block text-center border border-purple text-purple hover:bg-purple hover:text-white py-2 rounded-lg text-sm font-medium transition-colors">
              Book This Seva
            </a>
          </div>
        </div>
      ))}
    </div>

    <hr class="my-10 border-border" />

    <div class="text-center">
      <h2 class="text-2xl font-bold text-purple mb-2">Want to book a seva?</h2>
      <p class="text-muted text-sm mb-2">
        Contact us directly to book any seva. We accept UPI, bank transfer, and cash.
      </p>
      <p class="text-muted text-sm mb-4">
        Phone/WhatsApp: <strong>7558 148 198</strong>
      </p>
      <a href={`${base}/contact`} class="inline-block bg-purple hover:bg-purple-dark text-white px-6 py-2.5 rounded-lg text-sm font-medium transition-colors">
        Contact Temple Office
      </a>
    </div>
  </section>
</Layout>
