---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const events = [
  {
    title: 'Sri Krishna Janmashtami',
    date: 'August 2026',
    time: '4:00 PM - 12:30 AM',
    description: 'Grand celebration of Lord Krishna\'s appearance day. Join us for an evening of kirtan, drama performances depicting Krishna\'s pastimes, midnight abhishekam, and sumptuous prasadam feast.',
    highlight: true,
  },
  {
    title: 'Sunday Special Program',
    date: 'Every Sunday',
    time: '5:00 PM - 8:00 PM',
    description: 'Weekly program with ecstatic kirtan, enlightening discourse on Bhagavad Gita, and a delicious multi-course prasadam feast. Children through elders all benefit from this family program.',
    highlight: false,
  },
  {
    title: 'Gaura Purnima',
    date: 'March 2027',
    time: 'All Day',
    description: 'Celebration of the appearance of Lord Sri Chaitanya Mahaprabhu, who appeared approximately 500 years ago to spread the congregational chanting of the holy names.',
    highlight: true,
  },
  {
    title: 'Rama Navami',
    date: 'April 2027',
    time: '9:00 AM - 1:00 PM',
    description: 'Celebration of the appearance of Lord Ramachandra, the ideal king and the seventh incarnation of Lord Vishnu.',
    highlight: false,
  },
  {
    title: 'Narasimha Chaturdashi',
    date: 'May 2027',
    time: '6:00 PM - 9:00 PM',
    description: 'Appearance day of Lord Narasimhadeva, the half-man half-lion incarnation who appeared to protect His devotee Prahlad Maharaj.',
    highlight: false,
  },
  {
    title: 'Balaram Purnima',
    date: 'August 2026',
    time: 'All Day',
    description: 'Appearance day of Lord Balaram, the elder brother of Lord Krishna and the source of all spiritual strength.',
    highlight: false,
  },
  {
    title: 'Radhastami',
    date: 'September 2026',
    time: '6:00 PM - 9:00 PM',
    description: 'Appearance day of Srimati Radharani, the eternal consort of Lord Krishna and the embodiment of pure devotional love.',
    highlight: true,
  },
  {
    title: 'Damodara Deepotsava',
    date: 'Oct - Nov (Month-long)',
    time: 'Evening',
    description: 'A month-long festival of offering ghee lamps to Lord Damodara (Krishna). Devotees offer lamps daily while singing the Damodarashtakam prayers.',
    highlight: false,
  },
  {
    title: 'Bhagavad Gita Jayanti',
    date: 'December 2026',
    time: '6:00 PM - 9:00 PM',
    description: 'Celebration of the day when Lord Krishna spoke the Bhagavad Gita to Arjuna on the battlefield of Kurukshetra 5,000 years ago.',
    highlight: false,
  },
  {
    title: 'Ekadashi Fasting',
    date: 'Twice Monthly',
    time: 'All Day',
    description: 'Sacred fasting day observed on the 11th day of each lunar fortnight. Devotees fast from grains and beans and increase their chanting and hearing.',
    highlight: false,
  },
];
---

<Layout title="Festivals & Events" description="Upcoming festivals and events at ISKCON Tirunelveli">
  <section class="relative text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://iskcontirunelveli.com/wp-content/uploads/2019/10/KRISHNA_JEYANTHI_MADURAI_ISKCON_RADHAMATHURAPATHI_01.jpg"
        alt="ISKCON Ratha Yatra Festival"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative max-w-4xl mx-auto text-center py-16 px-4">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">Festivals & Events</h1>
      <p class="text-white/80 max-w-xl mx-auto">
        Join us in celebrating the timeless Vedic festivals at Sri Sri Krishna Balaram Temple.
        All events are free and open to everyone.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="space-y-4">
      {events.map(event => (
        <div class:list={[
          'border rounded-lg overflow-hidden hover:border-purple/30 transition-colors bg-white',
          event.highlight ? 'border-purple/40' : 'border-border',
        ]}>
          <div class="p-6">
            <div class="flex flex-col sm:flex-row items-start gap-4">
              <div class="text-center border border-border rounded-lg px-4 py-3 w-full sm:w-auto sm:min-w-[100px] shrink-0">
                <div class="text-purple font-bold text-sm">{event.date}</div>
                <div class="text-muted text-xs mt-0.5">{event.time}</div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-bold text-lg text-dark">{event.title}</h3>
                  {event.highlight && (
                    <span class="text-xs bg-purple/10 text-purple px-2 py-0.5 rounded-full font-medium">Featured</span>
                  )}
                </div>
                <p class="text-muted text-sm mt-2 leading-relaxed">{event.description}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
