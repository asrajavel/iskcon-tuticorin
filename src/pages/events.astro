---
import Layout from '../layouts/Layout.astro';

const events = [
  {
    title: 'Janmashtami 2026',
    date: 'August 14, 2026',
    time: '4:00 PM - 12:30 AM',
    description: 'Grand celebration of Lord Krishna\'s appearance day. Join us for an evening of kirtan, drama performances depicting Krishna\'s pastimes, abhishekam at midnight, and sumptuous prasadam feast.',
    highlight: true,
  },
  {
    title: 'Sunday Love Feast',
    date: 'Every Sunday',
    time: '5:00 PM - 8:00 PM',
    description: 'Weekly program featuring ecstatic kirtan, enlightening discourse on Bhagavad Gita, and a delicious multi-course prasadam feast. Everyone is welcome!',
    highlight: false,
  },
  {
    title: 'Gaura Purnima',
    date: 'March 2027',
    time: 'All Day',
    description: 'Celebration of the appearance of Lord Chaitanya Mahaprabhu, the most merciful incarnation who spread the Hare Krishna movement 500 years ago.',
    highlight: false,
  },
  {
    title: 'Ratha Yatra',
    date: 'July 2026',
    time: '8:00 AM - 6:00 PM',
    description: 'The grand chariot festival of Lord Jagannath through the streets of Thoothukudi. Massive procession with kirtan, dance, and free prasadam distribution.',
    highlight: true,
  },
  {
    title: 'Govardhan Puja',
    date: 'October 2026',
    time: '9:00 AM - 1:00 PM',
    description: 'Celebration of Lord Krishna lifting Govardhan Hill. Features a grand Annakut (hill of food) offering with 108+ preparations.',
    highlight: false,
  },
  {
    title: 'Kirtan Mela',
    date: 'Monthly (Last Saturday)',
    time: '6:00 PM - 9:00 PM',
    description: 'An evening of continuous kirtan with visiting kirtaniyas from ISKCON centers across South India. Deep, meditative chanting experience.',
    highlight: false,
  },
];
---

<Layout title="Events" description="Upcoming festivals and events at ISKCON Thoothukudi">
  <section class="relative text-white overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://upload.wikimedia.org/wikipedia/commons/9/9d/Rath_yatra_festival_by_ISKCON_Durgapur_in_Paschim_Bardhaman_district_of_West_Bengal%2C_India%2C_photographed_by_Yogabrata_Chakraborty_2.jpg"
        alt="ISKCON Ratha Yatra Festival"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-black/60"></div>
    </div>
    <div class="relative max-w-4xl mx-auto text-center py-16 px-4">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">Events & Festivals</h1>
      <p class="text-white/80 max-w-xl mx-auto">
        Join us in celebrating the timeless Vedic festivals and special programs
        throughout the year. All events are free and open to everyone.
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="space-y-4">
      {events.map(event => (
        <div class:list={[
          'border rounded-lg overflow-hidden hover:border-purple/30 transition-colors bg-white',
          event.highlight ? 'border-purple/40' : 'border-border',
        ]}>
          <div class="p-6">
            <div class="flex flex-col sm:flex-row items-start gap-4">
              <div class="text-center border border-border rounded-lg px-4 py-3 w-full sm:w-auto sm:min-w-[100px] shrink-0">
                <div class="text-purple font-bold text-sm">{event.date}</div>
                <div class="text-muted text-xs mt-0.5">{event.time}</div>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-bold text-lg text-dark">{event.title}</h3>
                  {event.highlight && (
                    <span class="text-xs bg-purple/10 text-purple px-2 py-0.5 rounded-full font-medium">Featured</span>
                  )}
                </div>
                <p class="text-muted text-sm mt-2 leading-relaxed">{event.description}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
